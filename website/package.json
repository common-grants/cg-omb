{
  "name": "website",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.34.3",
  "scripts": {
    "sync:schemas": "rm -rf public/schemas && mkdir -p public/schemas && cp -R ../schemas/sde ../schemas/ic public/schemas/",
    "dev": "pnpm run sync:schemas && astro dev",
    "start": "pnpm run dev",
    "build": "pnpm run sync:schemas && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "format": "prettier --write .",
    "check:format": "prettier --check .",
    "ci": "pnpm run check:format && pnpm run check && pnpm run build",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.41.3",
    "astro": "^7.1.3",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^4.20251001.0",
    "@types/node": "^24.5.2",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.42.0"
  }
}
