{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AssistanceTypeCode.schema.json",
  "title": "AssistanceTypeCode",
  "description": "A code that indicates the form/legal instrument in which assistance is transmitted from the federal government, is initially received for use or distribution by the recipient, and in part determines the policy requirements that apply to the federal assistance as well as agency and recipient responsibilities underneath it.",
  "type": "string",
  "pattern": "^[A-z][0-9]{3}$",
  "minLength": 4,
  "maxLength": 4,
  "oneOf": [
    {
      "const": "F001",
      "title": "Grant"
    },
    {
      "const": "F002",
      "title": "Cooperative Agreement"
    },
    {
      "const": "F003",
      "title": "Direct Loan"
    },
    {
      "const": "F004",
      "title": "Loan Guarantee"
    },
    {
      "const": "F005",
      "title": "Indemnity/Insurance (non-loan)"
    },
    {
      "const": "F006",
      "title": "Direct Payment for Specified Use"
    },
    {
      "const": "F007",
      "title": "Direct Payment with Unrestricted Use"
    },
    {
      "const": "F008",
      "title": "Asset Forfeiture/Equitable Sharing"
    },
    {
      "const": "F009",
      "title": "Sale, Exchange, or Donation of Property and Goods"
    },
    {
      "const": "F010",
      "title": "Other Financial Assistance"
    },
    {
      "const": "N001",
      "title": "Use of Property, Facilities, and Equipment"
    },
    {
      "const": "N002",
      "title": "Provision of Specialized Services"
    },
    {
      "const": "N003",
      "title": "Advisory Services"
    },
    {
      "const": "N004",
      "title": "Dissemination of Technical Information"
    },
    {
      "const": "N005",
      "title": "Training"
    },
    {
      "const": "N006",
      "title": "Investigation of Complaints"
    },
    {
      "const": "N007",
      "title": "Other Non-Financial Assistance"
    }
  ],
  "x-cdmEntity": "Assistance Type",
  "x-grantsActivityReferences": [
    "GRM.010.010 Grant Program Set-up and Maintenance",
    "GRM.010.020 Grant Program Funding Opportunity"
  ],
  "x-dataGroups": [
    "Assistance Listing (AL) Information",
    "AL Obligation",
    "Notice of Funding Opportunity (NOFO) Information",
    "NOFO Basic Information"
  ],
  "x-relatedElements": [
    "(2) AssistanceType",
    "(3) Obligation - Assistance Type",
    "(10) Funding Instrument Type, Opportunity Category"
  ],
  "x-descriptionSource": [
    "(2) Modified"
  ],
  "x-references": [
    "(1) 2 CFR 200.203",
    "(2) GSDM v1.1",
    "(3) SAM.gov Assistance Listing",
    "(10) Grants.gov"
  ]
}